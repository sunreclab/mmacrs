```gitignore
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Compiled Python files
*.cpython-*.pyc

# Logs and temporary files
*.log
*.tmp
*.swp

# Environment files
.env
.env.local
*.env.*

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo

# Coverage reports
.coverage
coverage/
htmlcov/

# Distribution / packaging
dist/
build/
*.egg-info/
```